# Copy to .env for local overrides (docker-compose loads it if present).
# Everything here has a sensible default in docker-compose.yaml already.

# Authentik SSO (leave empty to use username/password only)
#AUTHENTIK_SERVER_URL=https://auth.example.com/application/o/pulsegrid/
#AUTHENTIK_CLIENT_ID=
#AUTHENTIK_CLIENT_SECRET=

# On-demand Authentik user provisioning for org invitations (optional):
# service-account API token + slug of an enrollment flow with an
# Invitation stage. Public URL derived from AUTHENTIK_SERVER_URL if unset.
#AUTHENTIK_API_TOKEN=
#AUTHENTIK_ENROLLMENT_FLOW=pulsegrid-enrollment
#AUTHENTIK_PUBLIC_URL=

# Audit-event forwarding to the vels.online MSSP platform
# (events are always logged to DB + stdout; this adds alert-ingest forwarding)
#MSSP_URL=https://vels.online
#MSSP_ORG=your-mssp-org-slug
#MSSP_API_TOKEN=
#MSSP_MIN_SEVERITY=medium

# Outgoing email (empty = emails printed to the console)
#EMAIL_HOST=
#EMAIL_PORT=587
#EMAIL_HOST_USER=
#EMAIL_HOST_PASSWORD=
#DEFAULT_FROM_EMAIL=pulsegrid@example.com
